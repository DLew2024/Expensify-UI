{
	"name": "expensify-project",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"generate:types": "openapi-typescript http://localhost:5073/openapi/v1.json -o src/api/generated/GeneratedDTOs.ts && node src/api/scripts/replace-uuid-with-guid.mjs",
		"predev": "npm run generate:types",
		"dev": "vite --port 3000",
		"format": "biome format .",
		"check": "biome check .",
		"pretty": "biome check --write .",
		"build": "npm run typecheck",
		"build:project": "npm run build:client && npm run build:server && npm run typecheck",
		"build:client": "vite build --outDir dist/client && npm run typecheck",
		"build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
		"typecheck": "tsc --noEmit",
		"preview": "cross-env NODE_ENV=production node server"
	},
	"dependencies": {
		"@emotion/cache": "^11.14.0",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@mui/icons-material": "^7.3.7",
		"@mui/material": "^7.3.7",
		"@mui/x-date-pickers": "^8.25.0",
		"@reduxjs/toolkit": "^2.11.2",
		"axios": "^1.18.1",
		"clsx": "^2.1.1",
		"compression": "^1.8.1",
		"dayjs": "^1.11.19",
		"emoji-picker-react": "^4.18.0",
		"express": "^5.2.1",
		"moment": "^2.30.1",
		"numeral": "^2.0.6",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"react-hot-toast": "^2.6.0",
		"react-icons": "^5.6.0",
		"react-redux": "^9.2.0",
		"react-router": "^7.12.0",
		"react-router-dom": "^7.13.2",
		"recharts": "^3.8.1",
		"sass": "^1.97.2",
		"sirv": "^3.0.2",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/express": "^5.0.6",
		"@types/node": "^24.10.2",
		"@types/numeral": "^2.0.5",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.2.2",
		"cross-env": "^10.1.0",
		"openapi-typescript": "^7.13.0",
		"typescript": "~5.9.3",
		"vite": "^7.2.7"
	}
}
